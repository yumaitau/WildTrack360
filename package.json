{
  "name": "wildtrack360",
  "version": "0.1.0",
  "description": "Wildlife conservation management system for tracking animal lifecycle, carer compliance, and regulatory reporting across Australian jurisdictions",
  "license": "MPL-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/yumaitau/WildTrack360.git"
  },
  "homepage": "https://github.com/yumaitau/WildTrack360",
  "bugs": {
    "url": "https://github.com/yumaitau/WildTrack360/issues"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css}\"",
    "typecheck": "tsc --noEmit",
    "openapi:generate": "tsx --tsconfig tsconfig.scripts.json scripts/openapi-coverage.ts --write",
    "openapi:check": "tsx --tsconfig tsconfig.scripts.json scripts/openapi-coverage.ts",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:community": "tsx prisma/community-seed.ts",
    "db:studio": "prisma studio",
    "db:migrate:prod": "npx prisma migrate deploy",
    "db:reset": "prisma migrate reset",
    "db:seed:screenshots": "tsx prisma/screenshot-seed.ts",
    "record:clips": "tsx scripts/record-product-clips.ts",
    "orgs:snapshot": "tsx --tsconfig tsconfig.scripts.json scripts/snapshot-clerk-orgs.ts",
    "orgs:backfill": "tsx --tsconfig tsconfig.scripts.json scripts/backfill-orgs-from-clerk.ts",
    "orgs:drift": "tsx --tsconfig tsconfig.scripts.json scripts/check-org-drift.ts",
    "orgs:create": "tsx --tsconfig tsconfig.scripts.json scripts/create-organisation.ts",
    "charge-due": "tsx --tsconfig tsconfig.scripts.json src/scripts/charge-due-subscriptions.ts",
    "membership-reminders": "tsx --tsconfig tsconfig.scripts.json src/scripts/membership-reminders.ts",
    "refresh-tokens": "tsx --tsconfig tsconfig.scripts.json src/scripts/refresh-square-tokens.ts",
    "prod_start": "npm run db:migrate:prod && npm run start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:staging": "playwright test --config playwright.staging.config.ts",
    "test:e2e:staging:ui": "playwright test --config playwright.staging.config.ts --ui"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^4.0.111",
    "@asteasolutions/zod-to-openapi": "^7.3.4",
    "@aws-sdk/client-bedrock-runtime": "^3.1092.0",
    "@aws-sdk/client-s3": "^3.1053.0",
    "@aws-sdk/client-sns": "^3.1053.0",
    "@clerk/mcp-tools": "^0.3.1",
    "@clerk/nextjs": "^6.39.3",
    "@codemirror/autocomplete": "^6.20.2",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^4.1.3",
    "@prisma/client": "^6.14.0",
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-menubar": "^1.1.6",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-radio-group": "^1.2.3",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slider": "^1.2.3",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@react-email/render": "^2.0.8",
    "@react-google-maps/api": "^2.20.7",
    "@sentry/nextjs": "^10.40.0",
    "@square/web-sdk": "^2.1.0",
    "@tanstack/react-form": "^1.14.2",
    "@tanstack/react-table": "^8.19.3",
    "@tanstack/zod-form-adapter": "^0.42.1",
    "@types/archiver": "^7.0.0",
    "@types/nprogress": "^0.2.3",
    "@uiw/react-codemirror": "^4.25.10",
    "ai": "^6.0.194",
    "archiver": "^7.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^3.6.0",
    "dotenv": "^16.5.0",
    "embla-carousel-react": "^8.6.0",
    "exceljs": "^4.4.0",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.475.0",
    "mcp-handler": "^1.1.0",
    "nanoid": "^5.1.7",
    "next": "^15.5.18",
    "nprogress": "^0.2.0",
    "patch-package": "^8.0.0",
    "prisma": "^6.14.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.60.0",
    "react-markdown": "^10.1.0",
    "recharts": "^2.15.1",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.12.2",
    "sonner": "^2.0.7",
    "square": "^44.1.0",
    "tailwind-merge": "^3.0.1",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.22.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@clerk/testing": "^2.2.5",
    "@eslint/eslintrc": "^3.3.3",
    "@playwright/test": "^1.60.0",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.33.0",
    "eslint-config-next": "^15.4.6",
    "playwright": "^1.60.0",
    "postcss": "^8.5.12",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.1",
    "typescript": "5.9.3",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "dompurify": "^3.4.0",
    "js-cookie": "^3.0.7",
    "next": {
      "postcss": "^8.5.10"
    },
    "tmp": "^0.2.6",
    "uuid": "^14.0.0",
    "esbuild": "0.28.1",
    "vite": "^7.3.2"
  }
}
