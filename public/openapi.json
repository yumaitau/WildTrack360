  "paths": {
    "/api/animals": {
      "get": {
        "summary": "List animals for the organisation (role-scoped)",
        "tags": [
          "Animals"
        ],
        "security": [
          {
            "clerkSession": []
          }
        ],
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "orgId",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "Animals with carer, records and photos",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/AnimalWithRelations"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Organization ID is required"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          }
        }
      },
      "post": {
        "summary": "Create an animal",
        "tags": [
          "Animals"
        ],
        "security": [
          {
            "clerkSession": []
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AnimalCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "The created animal",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Animal"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request body / organization required"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "422": {
            "description": "orgAnimalId already in use"
          }
        }
      }
    },
    "/api/animals/peek-id": {
      "get": {
        "summary": "Preview the next generated animal ID",
        "tags": [
          "Animals"
        ],
        "security": [
          {
            "clerkSession": []
          }
        ],
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "species",
            "in": "query"
          },
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "intakeDate",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "Preview of the next animal ID",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "preview": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "preview"
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/animals/{id}": {
      "patch": {
        "summary": "Update an animal",
        "tags": [
          "Animals"
        ],
        "security": [
          {
            "clerkSession": []
          }
        ],
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AnimalUpdate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The updated animal",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Animal"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request body"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "404": {
            "description": "Animal not found"
          },
          "422": {
            "description": "Invalid status transition or duplicate orgAnimalId"
          }
        }
      },
      "delete": {
        "summary": "Delete an animal (admin only)",
        "tags": [
          "Animals"
        ],
        "security": [
          {
            "clerkSession": []
          }
        ],
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Deleted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    }
                  },
                  "required": [
                    "ok"
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "404": {
            "description": "Animal not found"
          }
        }
      }
    },
