  ageDays      Int     @map("age_days")
  weightGrams  Float?  @map("weight_grams")
  headLengthMm Float?  @map("head_length_mm")
  earLengthMm  Float?  @map("ear_length_mm")
  armLengthMm  Float?  @map("arm_length_mm")
  legLengthMm  Float?  @map("leg_length_mm")
