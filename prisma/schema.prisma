// ─── Feature Flags ──────────────────────────────────────────────────────────
// Per-org rollout switch. The WildTrack360-Admin app is the source of truth
// for toggling: it writes rows here, and every gated route + API in the
// tenant app calls `isFeatureEnabled(orgId, feature)` before doing work.
// Default policy: feature is OFF when no row exists, so anything new must be
// explicitly opted in per org.

model OrgFeatureFlag {
  id                  String   @id @default(cuid())
  clerkOrganizationId String   @map("clerk_organization_id")
  feature             String // e.g. "MEMBERSHIP_PLATFORM"
  enabled             Boolean  @default(false)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@unique([clerkOrganizationId, feature])
  @@index([clerkOrganizationId])
  @@map("org_feature_flags")
}

// ─── Form Builder ───────────────────────────────────────────────────────────
// Generic custom-field primitive. First consumer is Member, but the polymorphic
// entityType enum lets future entities (donor surveys, intake assessments,
// volunteer apps) reuse the same template + submission shape.

enum FormEntityType {
  MEMBER
}

model FormTemplate {
  id                  String         @id @default(cuid())
  clerkOrganizationId String         @map("clerk_organization_id")
  entityType          FormEntityType @map("entity_type")
  name                String
  version             Int            @default(1)
  fieldsJson          Json           @map("fields_json")
  isActive            Boolean        @default(true) @map("is_active")
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  @@unique([clerkOrganizationId, entityType])
  @@index([clerkOrganizationId])
  @@map("form_templates")
}

// ─── Custom Forms ────────────────────────────────────────────────────────────
// Standalone org-defined data-collection forms (ported from WildForm360).
// A form's definition (capture toggles + field list) lives as JSON on the form
// row; every save snapshots an immutable CustomFormVersion so historical
// submissions can always be resolved against the exact schema they were
// captured under. Submissions carry a clientSubmissionId so offline mobile
// clients can sync idempotently.

enum CustomFormStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model CustomForm {
  id                  String           @id @default(cuid())
  clerkOrganizationId String           @map("clerk_organization_id")
  createdByUserId     String           @map("created_by_user_id")
  title               String
  slug                String
  description         String?
  status              CustomFormStatus @default(DRAFT)
  currentVersion      Int              @default(1) @map("current_version")
  definitionJson      Json             @map("definition_json")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")

  versions    CustomFormVersion[]
  submissions CustomFormSubmission[]

  @@unique([clerkOrganizationId, slug])
  @@index([clerkOrganizationId, status])
  @@map("custom_forms")
}

model CustomFormVersion {
  id                  String           @id @default(cuid())
  formId              String           @map("form_id")
  clerkOrganizationId String           @map("clerk_organization_id")
  version             Int
  createdByUserId     String           @map("created_by_user_id")
  changeSummary       String?          @map("change_summary")
  title               String
  slug                String
  description         String?
  status              CustomFormStatus
  definitionJson      Json             @map("definition_json")
  createdAt           DateTime         @default(now()) @map("created_at")

  form        CustomForm             @relation(fields: [formId], references: [id], onDelete: Cascade)
  submissions CustomFormSubmission[]

  @@unique([formId, version])
  @@index([clerkOrganizationId])
  @@map("custom_form_versions")
}

model CustomFormSubmission {
  id                     String   @id @default(cuid())
  clerkOrganizationId    String   @map("clerk_organization_id")
  formId                 String   @map("form_id")
  formVersionId          String?  @map("form_version_id")
  formVersionNumber      Int      @map("form_version_number")
  submittedByUserId      String   @map("submitted_by_user_id")
  clientSubmissionId     String?  @map("client_submission_id")
  observedAt             DateTime @map("observed_at")
  latitude               Float?
  longitude              Float?
  locationAccuracyMeters Float?   @map("location_accuracy_meters")
  photoUrls              Json     @default("[]") @map("photo_urls")
  weatherJson            Json?    @map("weather_json")
  valuesJson             Json     @map("values_json")
  notes                  String?
  deviceJson             Json?    @map("device_json")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  form        CustomForm         @relation(fields: [formId], references: [id], onDelete: Cascade)
  formVersion CustomFormVersion? @relation(fields: [formVersionId], references: [id], onDelete: SetNull)

  // Offline sync idempotency: a mobile client retrying a sync with the same
  // clientSubmissionId must not create a duplicate row. Postgres treats NULLs
  // as distinct, so web submissions without a client id are unaffected.
  @@unique([clerkOrganizationId, submittedByUserId, clientSubmissionId])
  @@index([clerkOrganizationId, formId])
  @@index([formId, observedAt])
  @@index([clerkOrganizationId, submittedByUserId])
  @@map("custom_form_submissions")
}

// ─── Membership ─────────────────────────────────────────────────────────────

enum MemberStatus {
  ACTIVE
  LAPSED
  CANCELLED
  DECEASED
}

enum BillingInterval {
  ONE_OFF
  MONTHLY
  ANNUAL
  LIFETIME
}

enum MembershipStatus {
  PENDING
  ACTIVE
  EXPIRED
  CANCELLED
}

enum GstHandling {
  NONE
  INCLUSIVE
  EXCLUSIVE
}

model Member {
  id                  String       @id @default(cuid())
  clerkOrganizationId String       @map("clerk_organization_id")
  clerkUserId         String?      @map("clerk_user_id") // null until portal claimed
  // Portal-invite tracking. We only send a Clerk invitation after the member
  // pays; the invitation id is kept so the org can see invite status and revoke
  // the pending Clerk account if needed. clerkUserId is set once they activate.
  clerkInvitationId   String?      @map("clerk_invitation_id")
  portalInvitedAt     DateTime?    @map("portal_invited_at")
  carerProfileId      String?      @unique @map("carer_profile_id")
  squareCustomerId    String?      @map("square_customer_id")
  squareCardId        String?      @map("square_card_id")
  email               String
  firstName           String       @map("first_name")
  lastName            String       @map("last_name")
  phone               String?
  addressLine1        String?      @map("address_line_1")
  addressLine2        String?      @map("address_line_2")
  suburb              String?
  state               String?
  postcode            String?
  country             String       @default("AU")
  memberNumber        String?      @map("member_number")
  status              MemberStatus @default(ACTIVE)
  joinedAt            DateTime     @default(now()) @map("joined_at")
  // When set, this member is a secondary member covered by the primary member's
  // household membership (family membership). Primary members have it null.
  primaryMemberId     String?      @map("primary_member_id")
  customFieldsJson    Json         @default("{}") @map("custom_fields_json")
  archivedAt          DateTime?    @map("archived_at")
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")

  memberships             Membership[]
  payments                Payment[]
  donations               Donation[]
  recurringSubscriptions  RecurringSubscription[]
  messages                MemberMessage[]
  carerProfile            CarerProfile?            @relation(fields: [carerProfileId], references: [id])
  carerInterests          CarerInterest[]
  membershipNotifications MembershipNotification[]
  primaryMember           Member?                  @relation("Household", fields: [primaryMemberId, clerkOrganizationId], references: [id, clerkOrganizationId], onDelete: NoAction)
  householdMembers        Member[]                 @relation("Household")

  @@unique([id, clerkOrganizationId])
  @@unique([clerkOrganizationId, email])
  @@unique([clerkOrganizationId, memberNumber])
  @@index([clerkOrganizationId, status])
  @@index([clerkUserId])
  @@index([primaryMemberId])
  @@map("members")
}

model MembershipTier {
  id                  String          @id @default(cuid())
  clerkOrganizationId String          @map("clerk_organization_id")
  name                String
  description         String?
  amountCents         Int             @map("amount_cents")
  currency            String          @default("AUD")
  billingInterval     BillingInterval @map("billing_interval")
  gstHandling         GstHandling     @default(NONE) @map("gst_handling")
  // Ordered list of member-facing benefit lines (string[]), shown on the tier
  // cards in the join flow and portal.
  benefitsJson        Json            @default("[]") @map("benefits_json")
  active              Boolean         @default(true)
  archivedAt          DateTime?       @map("archived_at")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  memberships Membership[]

  @@index([clerkOrganizationId, active])
  @@map("membership_tiers")
}

model Membership {
  id                      String           @id @default(cuid())
  clerkOrganizationId     String           @map("clerk_organization_id")
  memberId                String           @map("member_id")
  tierId                  String           @map("tier_id")
  periodStart             DateTime         @map("period_start")
  periodEnd               DateTime         @map("period_end")
  status                  MembershipStatus
  recurringSubscriptionId String?          @map("recurring_subscription_id")
  paymentId               String?          @map("payment_id")
  // Set for gifted / complimentary memberships granted without a payment; holds
  // the giver's name (or "Complimentary") for the recipient's card and emails.
  giftedBy                String?          @map("gifted_by")
  createdAt               DateTime         @default(now()) @map("created_at")

  member                Member                   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  tier                  MembershipTier           @relation(fields: [tierId], references: [id])
  recurringSubscription RecurringSubscription?   @relation(fields: [recurringSubscriptionId], references: [id])
  notifications         MembershipNotification[]

  @@unique([id, clerkOrganizationId])
  @@index([clerkOrganizationId, status])
  @@index([memberId, periodEnd])
  @@index([recurringSubscriptionId])
  @@map("memberships")
}

// Which lifecycle emails have already gone out for a membership, so the daily
// sweep is idempotent and never double-sends a reminder. One row per
// (membership, kind).
enum MembershipNotificationKind {
  RENEWAL_30
  RENEWAL_7
  RENEWAL_1
  LAPSED
  WINBACK_30
  WINBACK_90
}

model MembershipNotification {
  id                  String                     @id @default(cuid())
  clerkOrganizationId String                     @map("clerk_organization_id")
  membershipId        String                     @map("membership_id")
  memberId            String                     @map("member_id")
  kind                MembershipNotificationKind
  sentAt              DateTime                   @default(now()) @map("sent_at")

  membership Membership @relation(fields: [membershipId, clerkOrganizationId], references: [id, clerkOrganizationId], onDelete: Cascade)
  member     Member     @relation(fields: [memberId, clerkOrganizationId], references: [id, clerkOrganizationId], onDelete: Cascade)

  @@unique([membershipId, kind])
  @@index([clerkOrganizationId, sentAt])
  @@map("membership_notifications")
}

// A member (or prospective supporter) expressing interest in becoming a
// volunteer wildlife carer — the member→carer funnel. Admins triage these and
// onboard approved applicants into a full CarerProfile via the carer app.
enum CarerInterestStatus {
  NEW
  CONTACTED
  APPROVED
  DECLINED
}

model CarerInterest {
  id                  String              @id @default(cuid())
  clerkOrganizationId String              @map("clerk_organization_id")
  memberId            String?             @map("member_id")
  name                String
  email               String
  phone               String?
  experience          String?
  availability        String?
  message             String?
  status              CarerInterestStatus @default(NEW)
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  member Member? @relation(fields: [memberId, clerkOrganizationId], references: [id, clerkOrganizationId], onDelete: NoAction)

  @@index([clerkOrganizationId, status])
  @@index([clerkOrganizationId, memberId, status])
  @@map("carer_interests")
}

// ─── Square (app-fee / OAuth) ───────────────────────────────────────────────

enum PaymentKind {
  DONATION_ONE_OFF
  DONATION_RECURRING
  MEMBERSHIP_ONE_OFF
  MEMBERSHIP_RECURRING
}

enum PaymentStatus {
  REQUIRES_ACTION
  SUCCEEDED
  FAILED
  REFUNDED
}

// Per-org Square OAuth connection. The org authorises our app against THEIR
// Square account; we charge on their behalf with app_fee_money. Access tokens
// expire after 30 days — refreshed lazily via the refresh token. Tokens are
// stored encrypted at rest (AES-256-GCM, see src/lib/crypto.ts) because they
// authorise charges on the org's account.
model SquareConnection {
  clerkOrganizationId String    @id @map("clerk_organization_id")
  merchantId          String    @unique @map("merchant_id")
  locationId          String    @map("location_id")
  accessTokenEnc      String    @map("access_token_enc")
  refreshTokenEnc     String    @map("refresh_token_enc")
  tokenExpiresAt      DateTime  @map("token_expires_at")
  scopes              String[]
  connectedAt         DateTime  @default(now()) @map("connected_at")
  revokedAt           DateTime? @map("revoked_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  @@map("square_connections")
}

// Webhook idempotency marker. id = Square event_id; the dispatcher refuses to
// re-process a seen id, writing the marker before running handlers and rolling
// it back on handler failure so Square retries can re-enter.
model SquareEvent {
  id          String   @id
  type        String
  processedAt DateTime @default(now()) @map("processed_at")
  payload     Json

  @@index([type])
  @@map("square_events")
}

// Single-use, short-lived OAuth state nonce → org. Lets the Square OAuth
// callback (on one canonical host) recover the org without a session. Deleted
// on use; expired rows are pruned opportunistically.
model SquareOAuthState {
  state               String   @id
  clerkOrganizationId String   @map("clerk_organization_id")
  expiresAt           DateTime @map("expires_at")
  createdAt           DateTime @default(now()) @map("created_at")

  @@index([expiresAt])
  @@map("square_oauth_states")
}

model Payment {
  id                  String        @id @default(cuid())
  clerkOrganizationId String        @map("clerk_organization_id")
  memberId            String?       @map("member_id")
  kind                PaymentKind
  squarePaymentId     String?       @unique @map("square_payment_id")
  squareOrderId       String?       @map("square_order_id")
  amountCents         Int           @map("amount_cents")
  // Our 5% application fee (app_fee_money), deposited to the platform account.
  applicationFeeCents Int           @map("application_fee_cents")
  // Square's processing fee, known only once the payment settles — filled in
  // asynchronously by the payment.updated webhook.
  processingFeeCents  Int?          @map("processing_fee_cents")
  currency            String        @default("AUD")
  status              PaymentStatus
  receiptUrl          String?       @map("receipt_url")
  receiptNumber       String?       @map("receipt_number")
  metadata            Json?
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  member    Member?    @relation(fields: [memberId], references: [id])
  donations Donation[]

  @@index([clerkOrganizationId, status])
  @@index([clerkOrganizationId, createdAt])
  @@index([memberId])
  @@map("payments")
}

model Donation {
  id                      String   @id @default(cuid())
  clerkOrganizationId     String   @map("clerk_organization_id")
  memberId                String?  @map("member_id")
  donorEmail              String   @map("donor_email")
  donorName               String?  @map("donor_name")
  amountCents             Int      @map("amount_cents")
  feeCents                Int      @map("fee_cents")
  currency                String   @default("AUD")
  isAnonymous             Boolean  @default(false) @map("is_anonymous")
  message                 String?
  paymentId               String   @map("payment_id")
  recurringSubscriptionId String?  @map("recurring_subscription_id")
  createdAt               DateTime @default(now()) @map("created_at")

  member                Member?                @relation(fields: [memberId], references: [id])
  payment               Payment                @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  recurringSubscription RecurringSubscription? @relation(fields: [recurringSubscriptionId], references: [id])

  @@index([clerkOrganizationId, createdAt])
  @@index([memberId])
  @@map("donations")
}

enum SubStatus {
  PENDING
  ACTIVE
  PAST_DUE
  CANCELLED
}

enum SubscriptionKind {
  DONATION
  MEMBERSHIP
}

// A self-billed recurring charge. Square's native Subscriptions API can't
// attach app_fee_money, so we vault a card-on-file on the org's Square account
// and our own BullMQ worker charges it each cycle via CreatePayment +
// app_fee_money. `nextChargeAt` is the billing anchor the worker scans;
// `failedAttempts` drives dunning (PAST_DUE → CANCELLED after N misses).
model RecurringSubscription {
  id                  String           @id @default(cuid())
  clerkOrganizationId String           @map("clerk_organization_id")
  memberId            String?          @map("member_id")
  kind                SubscriptionKind
  tierId              String?          @map("tier_id")
  donorEmail          String           @map("donor_email")
  donorName           String?          @map("donor_name")
  amountCents         Int              @map("amount_cents")
  currency            String           @default("AUD")
  interval            BillingInterval
  status              SubStatus
  isAnonymous         Boolean          @default(false) @map("is_anonymous")
  squareCustomerId    String           @map("square_customer_id")
  squareCardId        String           @map("square_card_id")
  nextChargeAt        DateTime         @map("next_charge_at")
  lastChargedAt       DateTime?        @map("last_charged_at")
  failedAttempts      Int              @default(0) @map("failed_attempts")
  startedAt           DateTime         @map("started_at")
  cancelledAt         DateTime?        @map("cancelled_at")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")

  member      Member?      @relation(fields: [memberId], references: [id])
  donations   Donation[]
  memberships Membership[]

  @@index([clerkOrganizationId, status])
  @@index([memberId])
  @@index([status, nextChargeAt])
  @@map("recurring_subscriptions")
}

model ReceiptSequence {
  clerkOrganizationId String @map("clerk_organization_id")
  year                Int
  lastNumber          Int    @default(0) @map("last_number")

  @@id([clerkOrganizationId, year])
  @@map("receipt_sequences")
}

// ─── Member Communications ──────────────────────────────────────────────────

enum NewsPostStatus {
  DRAFT
  PUBLISHED
}

// Org-authored announcement / news item shown in the member portal feed. When
// published, an email is broadcast to active members (emailSentAt records when
// that happened so re-publishing doesn't re-spam).
model NewsPost {
  id                  String         @id @default(cuid())
  clerkOrganizationId String         @map("clerk_organization_id")
  title               String
  body                String
  status              NewsPostStatus @default(DRAFT)
  // Clerk user id of the admin who authored the post (for display/audit only).
  authorClerkUserId   String?        @map("author_clerk_user_id")
  authorName          String?        @map("author_name")
  publishedAt         DateTime?      @map("published_at")
  emailSentAt         DateTime?      @map("email_sent_at")
  recipientCount      Int?           @map("recipient_count")
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  @@index([clerkOrganizationId, status, publishedAt])
  @@map("news_posts")
}

// A direct message from an admin to a single member, shown in the member
// portal inbox and (optionally) emailed. Body is stored already merge-rendered
// so the portal and the email show identical text.
model MemberMessage {
  id                  String    @id @default(cuid())
  clerkOrganizationId String    @map("clerk_organization_id")
  memberId            String    @map("member_id")
  subject             String
  body                String
  sentByClerkUserId   String?   @map("sent_by_clerk_user_id")
  sentByName          String?   @map("sent_by_name")
  emailSentAt         DateTime? @map("email_sent_at")
  readAt              DateTime? @map("read_at")
  createdAt           DateTime  @default(now()) @map("created_at")

  member Member @relation(fields: [memberId, clerkOrganizationId], references: [id, clerkOrganizationId], onDelete: Cascade)

  @@index([clerkOrganizationId, createdAt])
  @@index([memberId, readAt])
  @@map("member_messages")
}

// ─── Community Beta ──────────────────────────────────────────────────────────
// Ported from the RangerOS Community beta. Community is deliberately
// product-wide across enabled WildTrack360 organisations. These models NEVER
// carry or join to operational records (Animal, Record, Photo, CarerProfile,
// etc.). Author identity is anchored to Clerk IDs, not local FK relations:
// CommunityProfile.clerkUserId is the Clerk user and homeClerkOrganizationId is
// the verified home-organisation captured at onboarding for access + optional
// badge display only. Access is gated by the OrgFeatureFlag key COMMUNITY_BOARD
// (missing row = disabled). Migrations are forward-only.

enum CommunityPostType {
  DISCUSSION
  QUESTION
}

enum CommunityContentStatus {
  PENDING
  PUBLISHED
  HELD
  REMOVED
  DELETED
  // Author-only staging: a post saved before submitting for moderation. Never
  // delivered to other members. Publishing moves it to PENDING and enqueues
  // moderation.
  DRAFT
}

enum CommunityReactionType {
  HELPFUL
  THANKS
  SUPPORT
  CELEBRATE
}

enum CommunityTargetType {
  POST
  COMMENT
  CHAT_MESSAGE
}

enum CommunityReportReason {
  SAFETY
  HARASSMENT
  SENSITIVE_LOCATION
  CULTURAL_INFORMATION
  PERSONAL_INFORMATION
  SPAM
  OTHER
}

enum CommunityReportStatus {
  OPEN
  REVIEWING
  RESOLVED
  DISMISSED
}

enum CommunityAppealStatus {
  OPEN
  REVIEWING
  UPHELD
  OVERTURNED
}

enum CommunityModerationJobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  NEEDS_REVIEW
  FAILED
}

enum CommunityModerationRecommendation {
  PUBLISH
  REVIEW
  HOLD
}

enum CommunityModerationSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum CommunityFeedbackType {
  FEATURE_REQUEST
  BUG
  CONFUSING_EXPERIENCE
  SAFETY_MODERATION
  OTHER
}

enum CommunityRequestedFeature {
  IMAGES_FILES
  REGIONAL_PRIVATE_GROUPS
  DIRECT_MESSAGES
  EVENTS
  BETTER_SEARCH
  MOBILE_PUSH
  ORGANISATION_PROFILES
  OTHER
}

enum CommunityFeedbackStatus {
  NEW
  REVIEWED
  PLANNED
  SHIPPED
  DECLINED
}

enum CommunityNotificationType {
  REPLY
  MENTION
  ACCEPTED_ANSWER
  REACTION_SUMMARY
  FOLLOWED_POST_ACTIVITY
  MODERATION_DECISION
  REPORT_OUTCOME
  APPEAL_OUTCOME
  BETA_ANNOUNCEMENT
}

enum CommunityEmailFrequency {
  OFF
  IMMEDIATE
  DAILY
  WEEKLY
}

enum CommunityProfileStatus {
  ACTIVE
  MUTED
  BANNED
  LEFT
}

enum CommunitySanctionType {
  WARNING
  MUTE
  BAN
}

enum CommunitySubscriptionTarget {
  POST
  CATEGORY
  CHAT_ROOM
}

enum CommunityEmailDeliveryStatus {
  PENDING
  SENT
  FAILED
  SUPPRESSED
}

model CommunityProfile {
  id                      String                 @id @default(cuid())
  // Clerk user ID — the stable community identity. No FK to a local User table.
  clerkUserId             String                 @unique
  // Verified home-organisation captured at onboarding. Community identity does
  // not change when the user switches their active Clerk organisation.
  homeClerkOrganizationId String
  // Denormalised org display name for the optional organisation badge, so DTOs
  // never join to operational organisation records.
  homeOrganisationName    String?
  displayName             String
  showOrganisationBadge   Boolean                @default(false)
  region                  String?
  guidelinesVersion       String?
  guidelinesAcceptedAt    DateTime?
  isModerator             Boolean                @default(false)
  status                  CommunityProfileStatus @default(ACTIVE)
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt

  posts                  CommunityPost[]
  comments               CommunityComment[]
  chatMessages           CommunityChatMessage[]
  reactions              CommunityReaction[]
  follows                CommunityFollow[]
  reports                CommunityReport[]
  feedback               CommunityBetaFeedback[]
  notifications          CommunityNotification[]          @relation("CommunityNotificationRecipient")
  notificationActions    CommunityNotification[]          @relation("CommunityNotificationActor")
  notificationPreference CommunityNotificationPreference?
  moderationEvents       CommunityModerationEvent[]
  rateLimitBuckets       CommunityRateLimitBucket[]
  appeals                CommunityAppeal[]
  sanctions              CommunitySanction[]              @relation("CommunitySanctionTarget")
  sanctionsCreated       CommunitySanction[]              @relation("CommunitySanctionActor")
  emailDeliveries        CommunityEmailDelivery[]
  subscriptions          CommunitySubscription[]
  blocksCreated          CommunityBlock[]                 @relation("CommunityBlockBlocker")
  blockedBy              CommunityBlock[]                 @relation("CommunityBlockBlocked")
  bookmarks              CommunityBookmark[]

  @@index([homeClerkOrganizationId])
}

// A personal mute: `blocker` hides all of `blocked`'s content for themselves.
// One-directional and distinct from reporting — no moderator involvement.
model CommunityBlock {
  id        String           @id @default(cuid())
  blockerId String
  blocker   CommunityProfile @relation("CommunityBlockBlocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId String
  blocked   CommunityProfile @relation("CommunityBlockBlocked", fields: [blockedId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())

  @@unique([blockerId, blockedId])
  @@index([blockedId])
}

model CommunityCategory {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  posts     CommunityPost[]
  chatRooms CommunityChatRoom[]

  @@index([isActive, sortOrder])
}

model CommunityPost {
  id                String                 @id @default(cuid())
  authorId          String
  author            CommunityProfile       @relation(fields: [authorId], references: [id], onDelete: Restrict)
  categoryId        String
  category          CommunityCategory      @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  type              CommunityPostType
  // Approved content remains visible while draft content is re-moderated.
  title             String?
  body              String?
  draftTitle        String
  draftBody         String
  status            CommunityContentStatus @default(PENDING)
  clientMutationId  String
  mentions          Json?
  acceptedCommentId String?                @unique
  acceptedComment   CommunityComment?      @relation("AcceptedCommunityComment", fields: [acceptedCommentId], references: [id], onDelete: SetNull)
  isPinned          Boolean                @default(false)
  isLocked          Boolean                @default(false)
  deletedAt         DateTime?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  lastActivityAt    DateTime               @default(now())

  comments  CommunityComment[]  @relation("CommunityPostComments")
  reactions CommunityReaction[]
  follows   CommunityFollow[]
  bookmarks CommunityBookmark[]

  @@unique([authorId, clientMutationId])
  @@index([status, lastActivityAt(sort: Desc), id])
  @@index([categoryId, type, status, lastActivityAt(sort: Desc)])
}

model CommunityComment {
  id               String                 @id @default(cuid())
  postId           String
  post             CommunityPost          @relation("CommunityPostComments", fields: [postId], references: [id], onDelete: Cascade)
  authorId         String
  author           CommunityProfile       @relation(fields: [authorId], references: [id], onDelete: Restrict)
  parentId         String?
  parent           CommunityComment?      @relation("CommunityCommentReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies          CommunityComment[]     @relation("CommunityCommentReplies")
  acceptedForPost  CommunityPost?         @relation("AcceptedCommunityComment")
  body             String?
  draftBody        String
  status           CommunityContentStatus @default(PENDING)
  clientMutationId String
  mentions         Json?
  deletedAt        DateTime?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  reactions CommunityReaction[]

  @@unique([authorId, clientMutationId])
  @@index([postId, status, createdAt, id])
  @@index([parentId])
}

model CommunityReaction {
  id            String                @id @default(cuid())
  profileId     String
  profile       CommunityProfile      @relation(fields: [profileId], references: [id], onDelete: Cascade)
  type          CommunityReactionType
  postId        String?
  post          CommunityPost?        @relation(fields: [postId], references: [id], onDelete: Cascade)
  commentId     String?
  comment       CommunityComment?     @relation(fields: [commentId], references: [id], onDelete: Cascade)
  chatMessageId String?
  chatMessage   CommunityChatMessage? @relation(fields: [chatMessageId], references: [id], onDelete: Cascade)
  createdAt     DateTime              @default(now())

  @@unique([profileId, type, postId])
  @@unique([profileId, type, commentId])
  @@unique([profileId, type, chatMessageId])
  @@index([postId, type])
  @@index([commentId, type])
  @@index([chatMessageId, type])
}

model CommunityFollow {
  id        String           @id @default(cuid())
  profileId String
  profile   CommunityProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  postId    String
  post      CommunityPost    @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())

  @@unique([profileId, postId])
  @@index([postId])
}

model CommunityBookmark {
  id        String           @id @default(cuid())
  profileId String
  profile   CommunityProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  postId    String
  post      CommunityPost    @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())

  @@unique([profileId, postId])
  @@index([postId])
}

model CommunityChatRoom {
  id              String             @id @default(cuid())
  slug            String             @unique
  name            String
  description     String?
  categoryId      String?
  category        CommunityCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  isPinned        Boolean            @default(false)
  isReadOnly      Boolean            @default(false)
  isArchived      Boolean            @default(false)
  slowModeSeconds Int                @default(0)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  messages CommunityChatMessage[]

  @@index([isArchived, isPinned, name])
}

model CommunityChatMessage {
  id               String                 @id @default(cuid())
  roomId           String
  room             CommunityChatRoom      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  authorId         String
  author           CommunityProfile       @relation(fields: [authorId], references: [id], onDelete: Restrict)
  parentId         String?
  parent           CommunityChatMessage?  @relation("CommunityChatReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies          CommunityChatMessage[] @relation("CommunityChatReplies")
  body             String?
  draftBody        String
  status           CommunityContentStatus @default(PENDING)
  clientMutationId String
  mentions         Json?
  deletedAt        DateTime?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  reactions CommunityReaction[]

  @@unique([authorId, clientMutationId])
  @@index([roomId, status, createdAt(sort: Desc), id])
  @@index([parentId])
}

model CommunityReport {
  id         String                @id @default(cuid())
  reporterId String
  reporter   CommunityProfile      @relation(fields: [reporterId], references: [id], onDelete: Restrict)
  targetType CommunityTargetType
  targetId   String
  reason     CommunityReportReason
  details    String?
  status     CommunityReportStatus @default(OPEN)
  reviewedAt DateTime?
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  @@unique([reporterId, targetType, targetId])
  @@index([status, createdAt])
  @@index([targetType, targetId])
}

model CommunityModerationJob {
  id             String                       @id @default(cuid())
  targetType     CommunityTargetType
  targetId       String
  contentHash    String
  title          String?
  body           String
  status         CommunityModerationJobStatus @default(QUEUED)
  attempts       Int                          @default(0)
  nextRunAt      DateTime                     @default(now())
  leaseExpiresAt DateTime?
  policyVersion  String
  modelId        String
  errorCode      String?
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime                     @updatedAt

  events CommunityModerationEvent[]

  @@index([status, nextRunAt])
  @@index([targetType, targetId, createdAt(sort: Desc)])
}

model CommunityModerationEvent {
  id             String                            @id @default(cuid())
  jobId          String
  job            CommunityModerationJob            @relation(fields: [jobId], references: [id], onDelete: Restrict)
  actorProfileId String?
  actorProfile   CommunityProfile?                 @relation(fields: [actorProfileId], references: [id], onDelete: SetNull)
  recommendation CommunityModerationRecommendation
  categories     String[]                          @default([])
  reasonCode     String
  severity       CommunityModerationSeverity
  policyVersion  String
  modelId        String
  contentHash    String
  createdAt      DateTime                          @default(now())

  @@index([jobId, createdAt])
  @@index([recommendation, createdAt])
}

model CommunityNotification {
  id          String                    @id @default(cuid())
  recipientId String
  recipient   CommunityProfile          @relation("CommunityNotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actorId     String?
  actor       CommunityProfile?         @relation("CommunityNotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  type        CommunityNotificationType
  targetType  CommunityTargetType?
  targetId    String?
  title       String
  dedupeKey   String
  readAt      DateTime?
  createdAt   DateTime                  @default(now())

  @@unique([recipientId, dedupeKey])
  @@index([recipientId, readAt, createdAt(sort: Desc)])
}

model CommunityNotificationPreference {
  id                      String                  @id @default(cuid())
  profileId               String                  @unique
  profile                 CommunityProfile        @relation(fields: [profileId], references: [id], onDelete: Cascade)
  emailEnabled            Boolean                 @default(false)
  frequency               CommunityEmailFrequency @default(OFF)
  timezone                String
  digestDay               Int                     @default(1)
  digestHour              Int                     @default(8)
  notifyReplies           Boolean                 @default(true)
  notifyMentions          Boolean                 @default(true)
  notifyAcceptedAnswers   Boolean                 @default(true)
  notifyFollowedPosts     Boolean                 @default(true)
  notifyCategories        Boolean                 @default(false)
  notifyChats             Boolean                 @default(false)
  notifyReactionSummaries Boolean                 @default(false)
  notifyBetaAnnouncements Boolean                 @default(true)
  preferenceVersion       Int                     @default(1)
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
}

model CommunityBetaFeedback {
  id                String                      @id @default(cuid())
  profileId         String
  profile           CommunityProfile            @relation(fields: [profileId], references: [id], onDelete: Restrict)
  type              CommunityFeedbackType
  message           String
  requestedFeatures CommunityRequestedFeature[] @default([])
  pageContext       String?
  contactConsent    Boolean                     @default(false)
  status            CommunityFeedbackStatus     @default(NEW)
  triageNote        String?
  roadmapUrl        String?
  reviewedById      String?
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt

  @@index([status, createdAt])
  @@index([profileId, createdAt])
}

model CommunityRateLimitBucket {
  id          String           @id @default(cuid())
  profileId   String
  profile     CommunityProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  action      String
  windowStart DateTime
  count       Int              @default(1)
  updatedAt   DateTime         @updatedAt

  @@unique([profileId, action, windowStart])
  @@index([windowStart])
}

model CommunityAppeal {
  id            String                @id @default(cuid())
  appellantId   String
  appellant     CommunityProfile      @relation(fields: [appellantId], references: [id], onDelete: Restrict)
  targetType    CommunityTargetType
  targetId      String
  explanation   String
  status        CommunityAppealStatus @default(OPEN)
  reviewerId    String?
  outcomeReason String?
  reviewedAt    DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@unique([appellantId, targetType, targetId])
  @@index([status, createdAt])
}

model CommunitySanction {
  id          String                @id @default(cuid())
  profileId   String
  profile     CommunityProfile      @relation("CommunitySanctionTarget", fields: [profileId], references: [id], onDelete: Cascade)
  type        CommunitySanctionType
  reason      String
  scope       String                @default("GLOBAL")
  startsAt    DateTime              @default(now())
  endsAt      DateTime?
  createdById String?
  createdBy   CommunityProfile?     @relation("CommunitySanctionActor", fields: [createdById], references: [id], onDelete: SetNull)
  revokedAt   DateTime?
  revokedById String?
  createdAt   DateTime              @default(now())

  @@index([profileId, startsAt(sort: Desc)])
  @@index([endsAt])
}

model CommunityEmailDelivery {
  id                String                       @id @default(cuid())
  recipientId       String
  recipient         CommunityProfile             @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  kind              String
  dedupeKey         String                       @unique
  preferenceVersion Int
  providerMessageId String?
  status            CommunityEmailDeliveryStatus @default(PENDING)
  errorCode         String?
  createdAt         DateTime                     @default(now())
  sentAt            DateTime?

  @@index([recipientId, createdAt(sort: Desc)])
  @@index([status, createdAt])
}

model CommunitySubscription {
  id             String                      @id @default(cuid())
  profileId      String
  profile        CommunityProfile            @relation(fields: [profileId], references: [id], onDelete: Cascade)
  targetType     CommunitySubscriptionTarget
  targetId       String
  inApp          Boolean                     @default(true)
  emailFrequency CommunityEmailFrequency?
  muted          Boolean                     @default(false)
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt

  @@unique([profileId, targetType, targetId])
  @@index([targetType, targetId])
}
