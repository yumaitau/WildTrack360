// ─── Call Log Models ────────────────────────────────────────────────────────

enum CallLogStatus {
  OPEN
  CLOSED
}

model CallLog {
  id       String        @id @default(cuid())
  dateTime DateTime      @map("date_time")
  status   CallLogStatus @default(OPEN)

  // Caller details
  callerName  String  @map("caller_name")
  callerPhone String? @map("caller_phone")
  callerEmail String? @map("caller_email")

  // Species involved
  species String?

  // Location / GPS where the animal was reported
  location    String?
  coordinates Json? // { lat: number, lng: number }
  suburb      String?
  postcode    String?

  // Notes / comments
  notes String?

  // Lookup values (free text stored, referencing org-specific lookup lists)
  reason   String? // from CallLogReason lookup
  referrer String? // from CallLogReferrer lookup
  action   String? // from CallLogAction lookup
  outcome  String? // from CallLogOutcome lookup

  // Taken by — auto-captured from Clerk auth
  takenByUserId   String  @map("taken_by_user_id")
  takenByUserName String? @map("taken_by_user_name")

  // Assigned to — which carer/coordinator the call is assigned to
  assignedToUserId   String? @map("assigned_to_user_id")
  assignedToUserName String? @map("assigned_to_user_name")

  // Link to Animal — optional FK
  animalId String? @map("animal_id")
  animal   Animal? @relation(fields: [animalId], references: [id], onDelete: SetNull)

  // Organisation scoping (multi-tenancy)
  clerkOrganizationId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Pindrop sessions linked to this call log
  pindropSessions PindropSession[]

  @@index([clerkOrganizationId])
  @@index([status])
  @@index([dateTime])
  @@map("call_logs")
}

// ─── Pindrop Session ────────────────────────────────────────────────────────
// A one-time secure link sent via SMS so a caller can share their location,
// contact details, and photos with the helpdesk operator.

enum PindropStatus {
  PENDING
  SUBMITTED
  EXPIRED
}

model PindropSession {
  id          String        @id @default(cuid())
  accessToken String        @unique
  status      PindropStatus @default(PENDING)

  // Caller-filled fields (submitted via public form)
  callerName  String?
  callerEmail String?
  callerPhone String?
  lat         Float?
  lng         Float?
  address     String?
  photoUrls   String[]
  callerNotes String?

  // Provenance
  userAgent   String?
  submittedAt DateTime?
  expiresAt   DateTime?

  // Link to Call Log
  callLogId String?  @map("call_log_id")
  callLog   CallLog? @relation(fields: [callLogId], references: [id], onDelete: SetNull)

  // Multi-tenancy
  clerkOrganizationId String
  clerkUserId         String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clerkOrganizationId])
  @@index([callLogId])
  @@index([status])
  @@map("pindrop_sessions")
}

